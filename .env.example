# =============================================================================
# Lead Intelligence System — Environment Variables Template
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# --- Supabase ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# --- Skip Sherpa (Step 2 enrichment — pay-per-call skip tracing) ---
SKIP_SHERPA_API_KEY=your-skip-sherpa-api-key

# --- USPS Address Validation (Step 1 enrichment — free) ---
# Register at: https://www.usps.com/business/web-tools-apis/
USPS_API_USER_ID=your-usps-api-user-id

# --- Twilio (SMS alerts — Tier A leads and source alerts) ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
OWNER_PHONE=+1XXXXXXXXXX

# --- SendGrid (email alerts — Tier A + B leads, daily digest, monthly report) ---
SENDGRID_API_KEY=your-sendgrid-api-key
OWNER_EMAIL=your-email@example.com
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# --- Lake County monthly email (sent from info@thevnagroup.com to kpotter@lakecountyohio.gov) ---
LAKE_COUNTY_FROM_EMAIL=info@thevnagroup.com

# --- BrightData Residential Proxy (existing zone — not used for Lake County CF bypass) ---
# Dashboard: https://brightdata.com → Proxies → Residential → Zone credentials
# Username format: customer-CUSTOMER_ID-zone-ZONE_NAME
BRIGHTDATA_HOST=brd.superproxy.io
BRIGHTDATA_PORT=33335
BRIGHTDATA_USERNAME=your-brightdata-username
BRIGHTDATA_PASSWORD=your-brightdata-password
BRIGHTDATA_API_KEY=your-brightdata-api-key

# --- BrightData Scraping Browser (Option A — Lake County Cloudflare bypass) ---
# The residential proxy (above) is hard-blocked by Cloudflare on phoenix.lakecountyohio.gov.
# Fix: add a Scraping Browser zone in your BrightData dashboard, then paste the WS URL here.
#
# Setup steps:
#   1. BrightData dashboard → Add Zone → Scraping Browser
#   2. Name it (e.g. "lake_county_scraper")
#   3. Copy the WebSocket endpoint from Zone → Access parameters
#      Format: wss://brd-customer-XXXX-zone-ZONE_NAME:PASSWORD@brd.superproxy.io:9222
#   4. Paste it below and restart the pipeline
#
# Once this is set, Lake County probate will auto-resume — no other changes needed.
BRIGHTDATA_SBR_WS=

# --- 2captcha (Mahoning County — reCAPTCHA v2 solving) ---
# Dashboard: https://2captcha.com → Account → API key
TWOCAPTCHA_API_KEY=your-2captcha-api-key

# --- CourtListener RECAP (bankruptcy agent — free, API key optional but recommended) ---
# Register at: https://www.courtlistener.com/sign-in/ → Profile → API token
# Without a key, requests are anonymous and rate-limited to 1 req/second.
COURTLISTENER_API_KEY=your-courtlistener-api-key

# --- PACER (bankruptcy agent fallback — $0.10/page for documents; case search is free) ---
# Register at: https://pacer.uscourts.gov/register-account
# Quarterly accounts under $30 are waived — 75% of users pay nothing.
PACER_USERNAME=your-pacer-username
PACER_PASSWORD=your-pacer-password

# --- Google Maps (address geocoding + Street View thumbnails) ---
# Create a key at: console.cloud.google.com → APIs & Services → Credentials
# Enable: Geocoding API, Street View Static API
# Free tier: $200/month credit (~40,000 geocode requests free)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Google Sheets (VA queue routing + Skip Matrix queue) ---
# Service account JSON path for gspread authentication
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json
GOOGLE_SHEET_ID=your-google-sheet-id
SKIP_MATRIX_SHEET_TAB=skip_matrix_queue
VA_QUEUE_SHEET_TAB=va_queue

# --- Mojo Power Dialer ---
# API key from mojodialer.com → Settings → API
MOJO_API_KEY=your-mojo-api-key

# --- Zapier → Mojo Power Dialer ---
# Push Zap: Webhooks (Catch Hook) → Mojo (Add Contact to List)
ZAPIER_MOJO_PUSH_URL=https://hooks.zapier.com/hooks/catch/XXXXXXX/XXXXXXX/
# Disposition Zap: Mojo (New Disposition) → Webhooks (POST to Supabase)
ZAPIER_MOJO_DISPOSITION_URL=https://hooks.zapier.com/hooks/catch/XXXXXXX/XXXXXXX/

# --- Disposition webhook server ---
WEBHOOK_API_KEY=generate-with-python3-c-import-secrets-print-secrets-token-hex-24
WEBHOOK_PORT=5001
